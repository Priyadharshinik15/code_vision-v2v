# Copy this file to .env and fill in real values.
# The app runs fine with NONE of these set — every integration below
# degrades gracefully to a safe local fallback (per the original spec).

SECRET_KEY=change-this-to-a-random-string
DATABASE_URL=sqlite:///rakshita.db

# Optional: real SOS SMS via Twilio. If unset, SOS alerts are logged
# to the database and printed to the console instead of sent.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Comma-separated emails that get auto-promoted to admin (role="admin")
# the moment they register or log in. Simplest possible bootstrap for a
# demo — replace with real role management before production.
ADMIN_EMAILS=admin@example.com

# Off by default, exactly as originally scoped. Turn on to enable the
# Aadhaar QR upload flow (web: /kyc, mobile: /api/mobile/kyc/upload).
# Reminder: this reads the printed QR only, it does NOT verify UIDAI's
# digital signature — see aadhaar_kyc.py for the full disclosure.
AADHAAR_KYC_ENABLED=false
