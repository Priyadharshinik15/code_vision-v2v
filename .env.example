# Flask Configuration
SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///rakshita.db
FLASK_ENV=development

# Admin emails (comma-separated) — users with these emails are auto-promoted to admin on register
ADMIN_EMAILS=admin@example.com,superadmin@example.com

# Twilio SMS Configuration (Optional — comment out to disable SMS alerts)
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_FROM_NUMBER=+1234567890

# Aadhaar KYC Feature Flag (Optional — set to "true" to enable)
# AADHAAR_KYC_ENABLED=false

# CORS Origins (for mobile app API calls)
MOBILE_API_ORIGIN=http://localhost:8081
